# Copy to .env (gitignored) and fill in. These override matching local config fields.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Optional: choose where Blabbercast writes local settings.
# Defaults to config.local.json, which is gitignored.
# BLABBERCAST_CONFIG=config.local.json

# Optional: override the bundled Python interpreter path
# BLABBERCAST_PYTHON=C:\path\to\python.exe
